# Python cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Virtual environment
.venv/

# Environment variables (NEVER commit secrets)
.env

# OS files
.DS_Store
Thumbs.db

# IDE / Editor settings
.vscode/
.idea/

# Test cache
.pytest_cache/

# Generated outputs (re-created on every run)
outputs/
!outputs/.gitkeep

# Runtime data files (re-created automatically)
traces.jsonl
core/resolution_cache.json

# Logs
*.log

# Uploads
uploads/

# Mentor reference samples (not source code)
samples/
